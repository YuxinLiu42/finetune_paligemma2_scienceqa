# What `gcloud builds submit` uploads to the Cloud Build staging bucket.
#
# WHY: once this file exists, gcloud STOPS reading .gitignore. Our .gitignore
# ignored data/, so without this file the data/**/*.dvc pointers never got
# uploaded and `dvc pull` found nothing at train time.
# data/ dirs get checked out locally and are NOT tiny, so we exclude their
# contents below and ship ONLY the sibling .dvc pointers; dvc pull fetches the
# real data in-container from the GCS remote.
#
# SIDE EFFECT: because .gitignore is now ignored, anything it used to protect
# (secrets, caches) must be re-listed below or it gets uploaded.

# secrets — must never reach the staging bucket
.env
.env.*
*.env
.dvc/config.local
# rendered by envsubst (no secrets since the Secret Manager move, but they
# are per-submit artifacts that don't belong in the image):
cloud/vertex_config.yaml
cloud/vertex_eval.yaml
cloud/vertex_optimize.yaml

# DVC-tracked data: ship only the .dvc pointers, not the real data.
# .gitignore used to hide these dirs, but it's disabled now that this file exists.
data/processed/ScienceQA-IMG/
data/raw/ScienceQA-IMG/

# DVC (keep .dvc/config — it holds the GCS remote URL)
.dvc/cache
.dvc/tmp

# python / venv / build artifacts
.venv
__pycache__
*.pyc
*.egg-info
/build/
/dist/

# tooling caches
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov

# run artifacts
# Anchored to the repo root (leading /): an unanchored `models/` also matched
# src/scipali/models/ and silently dropped that subpackage from the upload —
# the 2026-07-19 manual API build failed its import smoke test exactly this way.
/wandb
/lightning_logs
/checkpoints
/outputs

# not COPY'd by any dockerfile — pure upload waste (tiny-paligemma alone is
# ~100MB and, being iCloud-evicted, broke the gcloud tarball with
# "unexpected end of data")
/tiny-paligemma/
/models/
/tests/
/reports/
profile_output.prof
import_time.log

# vcs / local tooling / os
.git
.claude
.DS_Store
.idea
.vscode
